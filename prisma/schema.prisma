generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 🏢 L'ANCRE MULTI-TENANT
// ==========================================

model Tenant {
  id          String   @id @default(uuid())
  companyName String   @map("company_name") 
  industry    String   
  logoUrl     String?  @map("logo_url") 
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users        User[]
  territories  Territory[]
  outlets      Outlet[]
  categories   ProductCategory[]
  skus         SKU[]
  orders       Order[]
  visits       Visit[]
  dynamicForms DynamicForm[]
  vendorStocks VendorStock[] 
  rtmTargets   RtmTarget[] 

  @@map("tenants")
}

// ==========================================
// 🔑 GOUVERNANCE & RÔLES MÉTIERS (6 NIVEAUX)
// ==========================================

enum UserRole {
  SALESCONNECTED_ADMIN  // Niveau 0 : Kimberlite Master Admin (Droits absolus et révocations mobiles)
  COMPANY_ADMIN         // Niveau 1 : Responsable Entreprise / Data Analyst (Gestion Master Data, Territoires, Stocks globaux)
  COMPANY_SUPERVISOR    // Niveau 2 : Superviseur / Commercial FanMilk (Gestion zones, routing, précommandes et création PDV)
  VAN_ADMIN             // Niveau 3 : Gestionnaire Distributeur / Grossiste (Approbation entrées usine, chargements Vans, performances)
  MERCHANDISER          // Niveau 4 : Merchandiseur (Audits No-code périodiques, relevés linéaires, repères GPS)
  VAN_SELLER            // Niveau 5 : Vendeur Van / Livreur Commando (Portefeuille jours, ventes réelles, création PDV terrain)
}

// ==========================================
// 👥 UTILISATEURS & COMMERCIAUX
// ==========================================

model User {
  id                  String           @id @default(uuid())
  tenantId            String           @map("tenant_id") 
  email               String           @unique
  password            String
  firstName           String
  lastName            String
  role                UserRole         @default(VAN_SELLER) // 🎯 Rôle typé et sécurisé par défaut au niveau 5
  phone               String
  matricule           String           @unique
  photoUrl            String?
  hireDate            DateTime?
  adminId             String?
  territoryId         String?
  assignedSectorId    String?
  managerId           String?
  isActive            Boolean          @default(true)
  status              String           @default("ACTIVE")
  twoFactorEnabled    Boolean          @default(false)
  twoFactorSecret     String?
  lastLogin           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments         Enrollments[]
  merchandisingChecks MerchCheck[]
  orders              Order[]
  validatedOutlets    Outlet[]         @relation("OutletValidator")
  proposedOutlets     Outlet[]         @relation("OutletProposer")
  refreshTokens       RefreshToken[]
  manager             User?            @relation("VendorManager", fields: [managerId], references: [id])
  vendors             User[]           @relation("VendorManager")
  userAssessments     UserAssessment[] @relation("UserAssessments")
  userLevel           UserLevel[]      @relation("UserLevel")
  userPoints          UserPoints[]
  vendorStockItems    VendorStock[]
  visits              Visit[]

  workflowTargets     WorkflowTarget[]
  submissions         Submission[]
  rtmTargets          RtmTarget[]

  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@index([territoryId])
  @@index([assignedSectorId])
  @@index([managerId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ==========================================
// 🗺️ STRUCTURATION DES SECTEURS GÉOGRAPHIQUES
// ==========================================

model Territory {
  id                  String      @id @default(uuid())
  tenantId            String      @map("tenant_id") 
  code                String      @unique
  name                String
  level               String      @default("SECTEUR")
  parentId            String?
  adminId             String?
  lat                 Float?
  lng                 Float?
  regions             String?
  communes            String?
  villes              String?
  quartiers           String?
  codesPostaux        String?
  population          Int?
  superficie          Float?
  densitePopulation   Float?
  potentielCommercial String?
  categorieMarche     String?
  typeZone            String?
  nombrePDVEstime     Int?
  tauxPenetration     Float?
  notes               String?
  isActive            Boolean     @default(true)
  createdBy           String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlets             Outlet[]
  parent              Territory?  @relation("TerritoryHierarchy", fields: [parentId], references: [id])
  children            Territory[] @relation("TerritoryHierarchy")

  @@index([tenantId])
  @@index([code])
  @@index([level])
  @@index([parentId])
  @@map("territories")
}

// ==========================================
// 🏪 CLIENTS & POINTS DE VENTE
// ==========================================

model Outlet {
  id                String       @id @default(uuid())
  tenantId          String       @map("tenant_id") 
  code              String       @unique
  name              String
  channel           String       
  segment           String?
  address           String?
  lat               Float?
  lng               Float
  openHours         String?
  territoryId       String
  sectorId          String?
  status            String       @default("PENDING")
  proposedBy        String?
  validatedBy       String?
  validatedAt       DateTime?
  validationComment String?
  osmPlaceId        String?
  osmMetadata       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  parentId          String?      @map("parent_id")
  parent            Outlet?      @relation("DistributionChain", fields: [parentId], references: [id])
  subOutlets        Outlet[]     @relation("DistributionChain")
  
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders            Order[]
  validator         User?        @relation("OutletValidator", fields: [validatedBy], references: [id])
  proposer          User?        @relation("OutletProposer", fields: [proposedBy], references: [id])
  territory         Territory    @relation(fields: [territoryId], references: [id])
  visits            Visit[]
  submissions       Submission[]

  @@index([tenantId])
  @@index([code])
  @@index([territoryId])
  @@index([status])
  @@index([parentId])
  @@map("outlets")
}

// ==========================================
// 📦 CATALOGUE PRODUIT STRUCTURÉ
// ==========================================

model ProductCategory {
  id          String               @id @default(uuid())
  tenantId    String               @map("tenant_id")
  name        String
  displayName String?
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subcategories ProductSubCategory[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("product_categories")
}

model ProductSubCategory {
  id          String          @id @default(uuid())
  name        String
  displayName String?
  categoryId  String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  brands      ProductBrand[]
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("product_sub_categories")
}

model ProductBrand {
  id                   String              @id @default(uuid())
  name                 String
  displayName          String?
  subProductCategoryId String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  subProductCategory   ProductSubCategory  @relation(fields: [subProductCategoryId], references: [id], onDelete: Cascade)
  packFormats          ProductPackFormat[]

  @@unique([subProductCategoryId, name])
  @@index([subProductCategoryId])
  @@map("product_brands")
}

model ProductPackFormat {
  id        String    @id @default(uuid())
  name      String
  displayName String?
  brandId   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  brand     ProductBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  packSizes SKU[]

  @@unique([brandId, name])
  @@index([brandId])
  @@map("product_pack_formats")
}

model SKU {
  id               String             @id @default(uuid())
  tenantId         String             @map("tenant_id") 
  name             String
  displayName      String?
  ean              String             @unique
  code             String?
  packFormatId     String
  description      String?
  shortDescription String?
  fullDescription  String?
  photo            String?
  priceHt          Float
  vatRate          Float              @default(19.6)
  baseUnit         String             @default("UNIT") @map("base_unit") 
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchCheckItems  MerchCheckItem[]
  orderLines       OrderLine[]
  packFormat       ProductPackFormat  @relation(fields: [packFormatId], references: [id], onDelete: Cascade)
  stockItems       VendorStock[]
  packagings       ProductPackaging[] 

  @@index([tenantId])
  @@index([packFormatId])
  @@index([active])
  @@map("skus")
}

model ProductPackaging {
  id               String   @id @default(uuid())
  skuId            String   @map("sku_id")
  name             String   
  conversionFactor Int      @map("conversion_factor") 
  
  sku              SKU      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  
  @@map("product_packagings")
}

// ==========================================
// 💼 COMMANDES & FACTURATION
// ==========================================

model Order {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  orderNumber   String         @unique
  outletId      String
  userId        String
  visitId       String?
  status        String         @default("PENDING")
  totalHt       Float
  totalTtc      Float
  vatRate       Float          @default(19.6)
  currency      String?        @default("XOF")
  taxTotal      Float?         @default(0)
  discountTotal Float?         @default(0)
  paymentMethod String?
  paymentStatus String         @default("PENDING")
  notes         String?
  orderDate     DateTime       @default(now())
  deliveryDate  DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  visit         Visit?         @relation(fields: [visitId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  outlet        Outlet         @relation(fields: [outletId], references: [id])
  items         OrderLine[]
  stockMovements StockHistory[]

  @@index([tenantId])
  @@index([outletId])
  @@index([userId])
  @@index([status])
  @@index([orderDate])
  @@map("orders")
}

model OrderLine {
  id            String   @id @default(uuid())
  orderId       String
  skuId         String
  quantity      Int
  unitPriceHt   Float
  totalPriceHt  Float
  totalPriceTtc Float
  createdAt     DateTime @default(now())
  sku           SKU      @relation(fields: [skuId], references: [id])
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([skuId])
  @@index([orderId, skuId]) 
  @@map("order_lines")
}

// ==========================================
// 📋 VISITES & ACTIONS TERRAIN
// ==========================================

model Visit {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  outletId    String
  userId      String
  status      String       @default("PLANNED")
  checkinAt   DateTime?
  checkinLat  Float?
  checkinLng  Float?
  checkoutAt  DateTime?
  checkoutLat Float?
  checkoutLng Float?
  durationMin Int?
  score       Int?
  notes       String?
  plannedDate DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchChecks MerchCheck[]
  orders      Order[]
  user        User         @relation(fields: [userId], references: [id])
  outlet      Outlet       @relation(fields: [outletId], references: [id])

  @@index([tenantId])
  @@index([outletId])
  @@index([userId])
  @@index([status])
  @@index([plannedDate])
  @@map("visits")
}

model MerchCheck {
  id          String           @id @default(uuid())
  visitId     String
  userId      String
  score       Int?
  notes       String?
  merchPhotos Int?             @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id])
  visit       Visit            @relation(fields: [visitId], references: [id], onDelete: Cascade)
  items       MerchCheckItem[]
  photos      MerchPhoto[]

  @@index([visitId])
  @@index([userId])
  @@map("merch_checks")
}

model MerchCheckItem {
  id                   String     @id @default(uuid())
  merchCheckId         String
  merchandisingCheckId String?
  skuId                String
  isVisible            Boolean    @default(false)
  isPriceCorrect       Boolean    @default(false)
  isWellStocked        Boolean    @default(false)
  comment              String?
  createdAt            DateTime   @default(now())
  sku                  SKU        @relation(fields: [skuId], references: [id])
  merchCheck           MerchCheck @relation(fields: [merchCheckId], references: [id], onDelete: Cascade)

  @@index([merchCheckId])
  @@index([skuId])
  @@map("merch_check_items")
}

model MerchPhoto {
  id                   String     @id @default(uuid())
  merchCheckId         String
  merchandisingCheckId String?
  fileKey              String
  imageUrl             String?
  lat                  Float?
  lng                  Float?
  takenAt              DateTime   @default(now())
  metadata             String?
  createdAt            DateTime   @default(now())
  merchCheck           MerchCheck @relation(fields: [merchCheckId], references: [id], onDelete: Cascade)

  @@index([merchCheckId])
  @@map("merch_photos")
}

// ==========================================
// 🚚 INVENTAIRES EMBARQUÉS & STOCKS CAMIONS
// ==========================================

model VendorStock {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id") 
  userId         String
  skuId          String
  quantity       Int            @default(0)
  alertThreshold Int            @default(10)
  updatedAt      DateTime       @updatedAt
  createdAt      DateTime       @default(now())
  movements      StockHistory[]
  sku            SKU            @relation(fields: [skuId], references: [id])
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade) 

  @@unique([userId, skuId])
  @@index([tenantId])
  @@index([userId])
  @@index([skuId])
  @@map("vendor_stocks")
}

model StockHistory {
  id           String      @id @default(uuid())
  stockItemId  String
  movementType String
  quantity     Int
  beforeQty    Int
  afterQty     Int
  notes        String?
  orderId      String?
  createdAt    DateTime    @default(now()) // 🎯 Réintroduction du champ manquant
  order        Order?      @relation(fields: [orderId], references: [id])
  stockItem    VendorStock @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@index([movementType])
  @@index([createdAt]) // 🎯 Maintenant l'index fonctionne à la perfection !
  @@map("stock_histories")
}

// ==========================================
// 🎯 OBJECTIFS COMMERCIAUX RTM STANDARDS
// ==========================================

model RtmTarget {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  userId           String   @map("user_id")          
  month            Int                               
  year             Int                               
  targetCa         Float    @default(0)              @map("target_ca")      
  targetVisits     Int      @default(0)              @map("target_visits")  
  targetStrikeRate Float    @default(0)              @map("target_strike_rate")
  createdAt        DateTime @default(now())           @map("created_at")
  updatedAt        DateTime @updatedAt                @map("updated_at")

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([tenantId])
  @@index([userId])
  @@map("rtm_targets")
}

// ==========================================
// 📝 LE FORMULAIRE NO-CODE & WORKFLOWS RELATIONNELS
// ==========================================

enum FieldType {
  TEXT
  NUMBER
  BOOLEAN
  GPS
  PHOTO
  RELATION_DROP_DOWN 
}

enum FormPurpose {
  SALES_ORDER
  STOCK_AUDIT
  ASSET_CHECK
  GENERIC_SURVEY
  COMMANDO_STREET     
}

model DynamicForm {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  title       String
  purpose     FormPurpose     @default(GENERIC_SURVEY)
  isWorkflow  Boolean         @default(true)      
  createdAt   DateTime        @default(now())     @map("created_at")
  updatedAt   DateTime        @updatedAt          @map("updated_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields      FormField[]
  submissions Submission[]
  targets     WorkflowTarget[] 

  @@index([tenantId])
  @@map("dynamic_forms")
}

model FormField {
  id               String      @id @default(uuid())
  formId           String      @map("form_id")
  label            String      
  type             FieldType
  isRequired       Boolean     @default(false) @map("is_required")
  order            Int         @default(0)     
  isForeignKey     Boolean     @default(false) @map("is_foreign_key")
  referencesFormId String?     @map("references_form_id") 

  form             DynamicForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("form_fields")
}

model WorkflowTarget {
  id            String      @id @default(uuid())
  formId        String      @map("form_id")
  userId        String      @map("user_id")     
  targetValue   Float       @map("target_value") 
  createdAt     DateTime    @default(now()) @map("created_at")

  form          DynamicForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([formId, userId])
  @@map("workflow_targets")
}

model Submission {
  id          String       @id @default(uuid())
  formId      String       @map("form_id")
  userId      String       @map("user_id")     
  outletId    String?      @map("outlet_id")   
  payload     Json         
  importedVia String?      @default("MOBILE")  
  createdAt   DateTime     @default(now())     @map("created_at")

  form        DynamicForm  @relation(fields: [formId], references: [id], onDelete: Cascade)
  outlet      Outlet?      @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([userId])
  @@index([outletId])
  @@index([formId, outletId])
  @@map("submissions")
}

// ==========================================
// 🎓 ACADÉMIE & FORMATIONS COMMERCIAUX
// ==========================================

model Course {
  id          String        @id @default(uuid())
  title       String
  description String?
  category    String
  contentType String        @default("document")
  contentUrl  String
  duration    Int?
  targetRoles String?
  points      Int           @default(0)
  badge       String?
  isPublished Boolean       @default(false)
  publishedAt DateTime?
  createdBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  chapters    Chapter[]
  enrollments Enrollments[]

  @@index([category])
  @@index([isPublished])
  @@map("courses")
}

model Chapter {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  order       Int
  contentType String
  contentUrl  String
  duration    Int?
  quiz        String?
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, order])
  @@map("chapters")
}

model Enrollments {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  status      String
  progress    Float     @default(0)
  completedAt DateTime?
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("enrollments")
}

model Assessment {
  id           String   @id @default(uuid())
  courseId     String
  title        String
  questions    String
  passingScore Float
  timeLimit    Int?
  createdAt    DateTime @default(now())

  @@index([courseId])
  @@map("assessments")
}

model UserAssessment {
  id           String   @id @default(uuid())
  userId       String
  assessmentId String
  score        Float
  passed       Boolean
  answers      String
  timeTaken    Int
  takenAt      DateTime @default(now())
  user         User     @relation("UserAssessments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assessmentId])
  @@map("user_assessments")
}

model UserPoints {
  id        String   @id @default(uuid())
  userId    String
  points    Int
  action    String
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_points")
}

model UserLevel {
  id         String   @id @default(uuid())
  userId     String
  level      Int      @default(1)
  totalPoints Int      @default(0)
  author     DateTime @default(now()) @map("achieved_at")
  user       User     @relation("UserLevel", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_levels")
}