generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  password            String
  firstName           String
  lastName            String
  role                String           @default("REP")
  phone               String
  matricule           String           @unique
  photoUrl            String?
  hireDate            DateTime?
  adminId             String?
  territoryId         String?
  assignedSectorId    String?
  managerId           String?
  isActive            Boolean          @default(true)
  status              String           @default("ACTIVE")
  twoFactorEnabled    Boolean          @default(false)
  twoFactorSecret     String?
  lastLogin           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  enrollments         Enrollment[]
  merchandisingChecks MerchCheck[]
  orders              Order[]
  validatedOutlets    Outlet[]         @relation("OutletValidator")
  proposedOutlets     Outlet[]         @relation("OutletProposer")
  refreshTokens       RefreshToken[]
  manager             User?            @relation("VendorManager", fields: [managerId], references: [id])
  vendors             User[]           @relation("VendorManager")
  userAssessments     UserAssessment[] @relation("UserAssessments")
  userLevel           UserLevel[]      @relation("UserLevel")
  userPoints          UserPoints[]
  vendorStockItems    VendorStock[]
  visits              Visit[]

  @@index([email])
  @@index([role])
  @@index([territoryId])
  @@index([assignedSectorId])
  @@index([managerId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Territory {
  id                  String      @id @default(uuid())
  code                String      @unique
  name                String
  level               String      @default("SECTEUR")
  parentId            String?
  adminId             String?
  lat                 Float?
  lng                 Float?
  regions             String?
  communes            String?
  villes              String?
  quartiers           String?
  codesPostaux        String?
  population          Int?
  superficie          Float?
  densitePopulation   Float?
  potentielCommercial String?
  categorieMarche     String?
  typeZone            String?
  nombrePDVEstime     Int?
  tauxPenetration     Float?
  notes               String?
  isActive            Boolean     @default(true)
  createdBy           String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  outlets             Outlet[]
  parent              Territory?  @relation("TerritoryHierarchy", fields: [parentId], references: [id])
  children            Territory[] @relation("TerritoryHierarchy")

  @@index([code])
  @@index([level])
  @@index([parentId])
}

model Outlet {
  id                String    @id @default(uuid())
  code              String    @unique
  name              String
  channel           String
  segment           String?
  address           String?
  lat               Float?
  lng               Float
  openHours         String?
  territoryId       String
  sectorId          String?
  status            String    @default("PENDING")
  proposedBy        String?
  validatedBy       String?
  validatedAt       DateTime?
  validationComment String?
  osmPlaceId        String?
  osmMetadata       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  orders            Order[]
  validator         User?     @relation("OutletValidator", fields: [validatedBy], references: [id])
  proposer          User?     @relation("OutletProposer", fields: [proposedBy], references: [id])
  territory         Territory @relation(fields: [territoryId], references: [id])
  visits            Visit[]

  @@index([code])
  @@index([territoryId])
  @@index([sectorId])
  @@index([status])
  @@index([proposedBy])
}

model ProductCategory {
  id            String               @id @default(uuid())
  name          String               @unique
  displayName   String?
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  subcategories ProductSubCategory[]
}

model ProductSubCategory {
  id          String          @id @default(uuid())
  name        String
  displayName String?
  categoryId  String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  brands      ProductBrand[]
  category    ProductCategory @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, name])
  @@index([categoryId])
}

model ProductBrand {
  id                   String              @id @default(uuid())
  name                 String
  displayName          String?
  subProductCategoryId String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  subProductCategory   ProductSubCategory  @relation(fields: [subProductCategoryId], references: [id])
  packFormats          ProductPackFormat[]

  @@unique([subProductCategoryId, name])
  @@index([subProductCategoryId])
}

model ProductPackFormat {
  id          String       @id @default(uuid())
  name        String
  displayName String?
  brandId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  brand       ProductBrand @relation(fields: [brandId], references: [id])
  packSizes   SKU[]

  @@unique([brandId, name])
  @@index([brandId])
}

model SKU {
  id               String            @id @default(uuid())
  name             String
  displayName      String?
  ean              String            @unique
  code             String?
  packFormatId     String
  description      String?
  shortDescription String?
  fullDescription  String?
  photo            String?
  priceHt          Float
  vatRate          Float             @default(19.6)
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  merchCheckItems  MerchCheckItem[]
  orderLines       OrderLine[]
  packFormat       ProductPackFormat @relation(fields: [packFormatId], references: [id])
  stockItems       VendorStock[]

  @@index([ean])
  @@index([code])
  @@index([packFormatId])
  @@index([active])
}

model Order {
  id             String         @id @default(uuid())
  orderNumber    String         @unique
  outletId       String
  userId         String
  visitId        String?
  status         String         @default("PENDING")
  totalHt        Float
  totalTtc       Float
  vatRate        Float          @default(19.6)
  currency       String?        @default("XOF")
  taxTotal       Float?         @default(0)
  discountTotal  Float?         @default(0)
  paymentMethod  String?
  paymentStatus  String         @default("PENDING")
  notes          String?
  orderDate      DateTime       @default(now())
  deliveryDate   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  visit          Visit?         @relation(fields: [visitId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  outlet         Outlet         @relation(fields: [outletId], references: [id])
  items          OrderLine[]
  stockMovements StockHistory[]

  @@index([orderNumber])
  @@index([outletId])
  @@index([userId])
  @@index([status])
  @@index([orderDate])
}

model OrderLine {
  id            String   @id @default(uuid())
  orderId       String
  skuId         String
  quantity      Int
  unitPriceHt   Float
  totalPriceHt  Float
  totalPriceTtc Float
  createdAt     DateTime @default(now())
  sku           SKU      @relation(fields: [skuId], references: [id])
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([skuId])
}

model Visit {
  id          String       @id @default(uuid())
  outletId    String
  userId      String
  status      String       @default("PLANNED")
  checkinAt   DateTime?
  checkinLat  Float?
  checkinLng  Float?
  checkoutAt  DateTime?
  checkoutLat Float?
  checkoutLng Float?
  durationMin Int?
  score       Int?
  notes       String?
  plannedDate DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  merchChecks MerchCheck[]
  orders      Order[]
  user        User         @relation(fields: [userId], references: [id])
  outlet      Outlet       @relation(fields: [outletId], references: [id])

  @@index([outletId])
  @@index([userId])
  @@index([status])
  @@index([plannedDate])
}

model MerchCheck {
  id          String           @id @default(uuid())
  visitId     String
  userId      String
  score       Int?
  notes       String?
  merchPhotos Int?             @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id])
  visit       Visit            @relation(fields: [visitId], references: [id], onDelete: Cascade)
  items       MerchCheckItem[]
  photos      MerchPhoto[]

  @@index([visitId])
  @@index([userId])
}

model MerchCheckItem {
  id                   String     @id @default(uuid())
  merchCheckId         String
  merchandisingCheckId String?
  skuId                String
  isVisible            Boolean    @default(false)
  isPriceCorrect       Boolean    @default(false)
  isWellStocked        Boolean    @default(false)
  comment              String?
  createdAt            DateTime   @default(now())
  sku                  SKU        @relation(fields: [skuId], references: [id])
  merchCheck           MerchCheck @relation(fields: [merchCheckId], references: [id], onDelete: Cascade)

  @@index([merchCheckId])
  @@index([skuId])
  @@index([merchandisingCheckId])
}

model MerchPhoto {
  id                   String     @id @default(uuid())
  merchCheckId         String
  merchandisingCheckId String?
  fileKey              String
  imageUrl             String?
  lat                  Float?
  lng                  Float?
  takenAt              DateTime   @default(now())
  metadata             String?
  createdAt            DateTime   @default(now())
  merchCheck           MerchCheck @relation(fields: [merchCheckId], references: [id], onDelete: Cascade)

  @@index([merchCheckId])
  @@index([merchandisingCheckId])
}

model VendorStock {
  id             String         @id @default(uuid())
  userId         String
  skuId          String
  quantity       Int            @default(0)
  alertThreshold Int            @default(10)
  updatedAt      DateTime       @updatedAt
  createdAt      DateTime       @default(now())
  movements      StockHistory[]
  sku            SKU            @relation(fields: [skuId], references: [id])
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skuId])
  @@index([userId])
  @@index([skuId])
}

model StockHistory {
  id           String      @id @default(uuid())
  stockItemId  String
  movementType String
  quantity     Int
  beforeQty    Int
  afterQty     Int
  notes        String?
  orderId      String?
  createdAt    DateTime    @default(now())
  order        Order?      @relation(fields: [orderId], references: [id])
  stockItem    VendorStock @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@index([movementType])
  @@index([createdAt])
  @@index([orderId])
}

model Course {
  id          String       @id @default(uuid())
  title       String
  description String?
  category    String
  contentType String       @default("document")
  contentUrl  String
  duration    Int?
  targetRoles String?
  points      Int          @default(0)
  badge       String?
  isPublished Boolean      @default(false)
  publishedAt DateTime?
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  chapters    Chapter[]
  enrollments Enrollment[]

  @@index([category])
  @@index([isPublished])
}

model Chapter {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  order       Int
  contentType String
  contentUrl  String
  duration    Int?
  quiz        String?
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id])

  @@unique([courseId, order])
  @@index([courseId])
}

model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  status      String
  progress    Float     @default(0)
  completedAt DateTime?
  course      Course    @relation(fields: [courseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Assessment {
  id           String   @id @default(uuid())
  courseId     String
  title        String
  questions    String
  passingScore Float
  timeLimit    Int?
  createdAt    DateTime @default(now())

  @@index([courseId])
}

model UserAssessment {
  id           String   @id @default(uuid())
  userId       String
  assessmentId String
  score        Float
  passed       Boolean
  answers      String
  timeTaken    Int
  takenAt      DateTime @default(now())
  user         User     @relation("UserAssessments", fields: [userId], references: [id])

  @@index([userId])
  @@index([assessmentId])
}

model UserPoints {
  id        String   @id @default(uuid())
  userId    String
  points    Int
  action    String
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserLevel {
  id          String   @id @default(uuid())
  userId      String
  level       Int      @default(1)
  totalPoints Int      @default(0)
  achievedAt  DateTime @default(now())
  user        User     @relation("UserLevel", fields: [userId], references: [id])

  @@index([userId])
}
